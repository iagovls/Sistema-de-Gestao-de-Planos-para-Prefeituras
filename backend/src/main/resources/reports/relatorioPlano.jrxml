	<subDataset name="PieChartDataSet" uuid="04022cfa-1ac2-4d6a-be0b-87cc8cc2160d">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="propostasdb"/>
		<parameter name="prefeituraId" class="java.lang.Integer">
			<defaultValueExpression><![CDATA[$P{prefeituraId}]]></defaultValueExpression>
		</parameter>
		<parameter name="planoId" class="java.lang.Integer">
			<defaultValueExpression><![CDATA[$P{planoId}]]></defaultValueExpression>
		</parameter>
		<queryString language="SQL">
			<![CDATA[SELECT
  CASE
    WHEN pr.status = '0' AND pr.meta < CURRENT_DATE THEN 'Vencido'
    WHEN pr.status = '1' THEN 'Concluído'
    WHEN pr.status = '0' AND pr.meta >= CURRENT_DATE THEN 'Em Andamento'
  END AS status_descricao,
  COUNT(*) AS total
FROM propostas pr
INNER JOIN planos pl ON pr.plano_id = pl.id
WHERE pr.plano_id = $P{planoId}
  AND pl.prefeitura_id = $P{prefeituraId}
GROUP BY status_descricao]]>
		</queryString>
		<field name="status_descricao" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="status_descricao"/>
			<property name="com.jaspersoft.studio.field.label" value="status_descricao"/>
		</field>
		<field name="total" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="total"/>
			<property name="com.jaspersoft.studio.field.label" value="total"/>
		</field>
	</subDataset>
	<subDataset name="datasetStatusPropostas" uuid="bca40e6a-f72d-4de6-8454-ee204014d3e0">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="propostasdb"/>
		<parameter name="planoId" class="java.lang.Integer">
			<defaultValueExpression><![CDATA[$P{planoId}]]></defaultValueExpression>
		</parameter>
		<parameter name="prefeituraId" class="java.lang.Integer">
			<defaultValueExpression><![CDATA[$P{prefeituraId}]]></defaultValueExpression>
		</parameter>
		<queryString language="SQL">
			<![CDATA[SELECT
  CASE
    WHEN pr.status = '1' THEN 'Concluído'
    WHEN pr.status = '0' AND pr.meta < CURRENT_DATE THEN 'Vencido'
    ELSE 'Em Andamento'
  END AS status,
  COUNT(*) AS total
FROM propostas pr
INNER JOIN planos pl ON pr.plano_id = pl.id
WHERE pr.plano_id = $P{planoId}
  AND pl.prefeitura_id = $P{prefeituraId}
GROUP BY
  CASE
    WHEN pr.status = '1' THEN 'Concluído'
    WHEN pr.status = '0' AND pr.meta < CURRENT_DATE THEN 'Vencido'
    ELSE 'Em Andamento'
  END]]>
		</queryString>
		<field name="status" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="status"/>
			<property name="com.jaspersoft.studio.field.label" value="status"/>
		</field>
		<field name="total" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="total"/>
			<property name="com.jaspersoft.studio.field.label" value="total"/>
		</field>
	</subDataset>
	<parameter name="planoId" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[$P{planoId}]]></defaultValueExpression>
	</parameter>
	<parameter name="prefeituraId" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[$P{prefeituraId}]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT propostas.titulo,
	propostas.meta,
	propostas.status,
	propostas.motivo,
	propostas.meta_permanente,
	propostas.ativa,
	prefeituras.name,
	prefeituras.logo_prefeitura,
	prefeituras.logo_cmdca,
	categorias.titulo AS titulo_categoria,
	eixos.titulo AS titulo_eixo,
	orgaos_gestores.titulo AS titulo_orgao,
	planos.titulo AS titulo_plano,
	eixos.id AS eixo_id
FROM propostas
	INNER JOIN planos ON 
	 propostas.plano_id = planos.id
	INNER JOIN prefeituras ON 
	 planos.prefeitura_id = prefeituras.id 
	INNER JOIN categorias ON 
	 propostas.categoria_id = categorias.id 
	INNER JOIN eixos ON 
	 propostas.eixo_id = eixos.id 
	INNER JOIN orgaos_gestores ON 
	 propostas.orgao_gestor_id = orgaos_gestores.id 
WHERE propostas.plano_id = $P{planoId}
	AND planos.prefeitura_id = $P{prefeituraId}
	 ORDER BY eixos.id]]>
	</queryString>
